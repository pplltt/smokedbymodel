<!doctype html>
<html lang="en" xmlns:th="http://www.thymeleaf.org">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home</title>

    <!-- Google Fonts -->
    <style>
        @import url("https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500&display=swap");

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: "Montserrat", sans-serif;
        }

        body {
            background-color: #f8f9fa;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
            padding: 40px 20px;
        }

        h1.site-title {
            font-size: 7rem;
            font-weight: 400;
            letter-spacing: 2px;
            color: #5D3559;
            margin-bottom: 60px;
            text-transform: uppercase;
        }

        .btn-group {
            display: flex;
            flex-direction: column;
            gap: 25px;
            align-items: center;
            width: 100%;
            max-width: 320px;
        }

        .custom-btn {
            background-color: #5D3559;
            color: white;
            border: none;
            border-radius: 22px;
            width: 100%;
            height: 70px;
            font-size: 1.4rem;
            font-weight: 500;
            cursor: pointer;
            text-decoration: none;
            line-height: 70px;
            transition: all 0.3s ease;
            box-shadow: 0 6px 10px rgba(0, 0, 0, 0.15);
        }

        .custom-btn:hover {
            background-color: #6e3f6b;
            transform: translateY(-3px);
        }

        .custom-btn:active {
            transform: translateY(0);
        }

        footer {
            margin-top: 80px;
            font-size: 0.9rem;
            color: #777;
        }

        @media (max-width: 768px) {
            h1.site-title {
                font-size: 2.8rem;
            }
            .custom-btn {
                font-size: 1.2rem;
                height: 60px;
                line-height: 60px;
            }
        }
    </style>
</head>
<body>

<h1 class="site-title">SmokedByModel</h1>

<div class="btn-group">
    <a th:href="@{/profile}" class="custom-btn">Profile</a>
    <a th:href="@{/brands}" class="custom-btn">Brands</a>
</div>

<footer>
    <p>&copy; 2025 SmokedByModel. All rights reserved.</p>
</footer>

</body>
</html>
